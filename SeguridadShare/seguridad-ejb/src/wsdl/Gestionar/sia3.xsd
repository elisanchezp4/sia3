<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:tns="http://soap.mineducacion.gov.co/11/seguridad/sia3" elementFormDefault="qualified" targetNamespace="http://soap.mineducacion.gov.co/11/seguridad/sia3" xmlns:xs="http://www.w3.org/2001/XMLSchema">
