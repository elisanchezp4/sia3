{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "@mt = 'An unhandled exception has occurred while executing the request.'"
        }
      }
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ]
  },
  "AllowedHosts": "*",
  "Ldap": {
    "Path": "192.168.32.124",
    "Port": "389",
    "UserDomainName": "SIA3_NET_APP",
    "UserDomainPassword": "",
    "Dn": "dc=pruebas,dc=mineducacion,dc=gov,dc=co",
    "Ou": "ou=usuarios externos",
    "KeyApi": "m3N2023*2023",
    "UserLogonDomain": "@pruebas.mineducacion.gov.co"

  }
}
