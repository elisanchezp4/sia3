<?xml version="1.0" encoding="UTF-8"?>
<!-- This file is not required if you don't need any extra configuration. -->
<faces-config version="2.0" xmlns="http://java.sun.com/xml/ns/javaee"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
        http://java.sun.com/xml/ns/javaee
        http://java.sun.com/xml/ns/javaee/web-facesconfig_2_0.xsd">
	<application>
		<message-bundle></message-bundle>
		<message-bundle>resources.application</message-bundle>
		<resource-bundle>
			<base-name>resources.etiquetas</base-name>
			<var>etq</var>
		</resource-bundle>
		<action-listener>org.primefaces.application.DialogActionListener</action-listener>
		<navigation-handler>org.primefaces.application.DialogNavigationHandler</navigation-handler>
		<view-handler>org.primefaces.application.DialogViewHandler</view-handler>
		<locale-config>
			<default-locale>es</default-locale>
		</locale-config>
		<locale-config>
			<default-locale>en</default-locale>
		</locale-config>
	</application>
	<navigation-rule>
		<from-view-id>*</from-view-id>
		<navigation-case>
			<from-outcome>inicio</from-outcome>
			<to-view-id>/seguridad/inicio.xhtml</to-view-id>
			<redirect />
		</navigation-case>
		<navigation-case>
			<from-outcome>nav_olvido_contrasenia</from-outcome>
			<to-view-id>/restablecerContrasenia.xhtml</to-view-id>
			<redirect />
		</navigation-case>
		<navigation-case>
			<from-outcome>finSesion</from-outcome>
			<to-view-id>/finSesion.xhtml</to-view-id>
			<redirect />
		</navigation-case>
	</navigation-rule>
</faces-config>
